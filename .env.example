# Banco de dados PostgreSQL
DATABASE_URL=postgres://postgres:password@localhost:5432/arm_market_placer

# Sessão (mínimo 32 caracteres, use: openssl rand -hex 32)
SESSION_SECRET=troque-por-uma-chave-aleatoria-de-pelo-menos-32-caracteres

# Servidor
PORT=3000
NODE_ENV=development

# ── Magazord ────────────────────────────────────────────────
MAGAZORD_API_URL=https://api.magazord.com.br
MAGAZORD_API_KEY=
MAGAZORD_STORE_ID=

# ── Mercado Livre ────────────────────────────────────────────
ML_APP_ID=
ML_APP_SECRET=
# Seller ID numérico da conta conectada (obtido após OAuth)
ML_SELLER_ID=
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# ── TikTok Shop ──────────────────────────────────────────────
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_SHOP_CIPHER=
TIKTOK_ACCESS_TOKEN=
