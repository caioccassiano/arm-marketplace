{
  "name": "arm-market-placer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:all": "concurrently -n api,web -c blue,green \"pnpm dev\" \"pnpm client:dev\"",
    "build": "pnpm client:build && tsc -p tsconfig.build.json",
    "start": "node dist/migrate.js && node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed/index.ts",
    "client:dev": "cd client && pnpm dev",
    "client:build": "cd client && pnpm build"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/session": "^11.0.1",
    "@fastify/static": "^8.1.1",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "postgres": "^3.4.5",
    "xlsx": "^0.18.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
